{
  "name": "greybeard-mvp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.13.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/seed.ts",
    "db:reset": "tsx src/lib/seed.ts reset",
    "staging:up": "docker compose -f docker-compose.staging.yml up -d",
    "staging:down": "docker compose -f docker-compose.staging.yml down -v",
    "staging:logs": "docker compose -f docker-compose.staging.yml logs -f app",
    "audit": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@neondatabase/serverless": "^0.10.4",
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.1",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "drizzle-orm": "0.45.2",
    "next": "15.5.18",
    "next-auth": "5.0.0-beta.31",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "^4.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.18",
    "postcss": "8.5.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=11.11.0"
  }
}
