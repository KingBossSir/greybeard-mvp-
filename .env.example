# --- Database (Neon Postgres) -------------------------------------------------
# Accepted aliases at runtime: POSTGRES_URL, POSTGRES_PRISMA_URL.
# For migrations, POSTGRES_URL_NON_POOLING / DATABASE_URL_NON_POOLING are also supported.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Auth (NextAuth v5) -------------------------------------------------------
# Generate: openssl rand -base64 32
# Accepted alias at runtime: NEXTAUTH_SECRET
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Email (magic link via Resend) -------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@greybeard.app

# --- Ledger signing (ed25519, hex-encoded 32-byte seed) ----------------------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LEDGER_SIGNING_KEY=

# --- Vault encryption (AES-256-GCM key, hex-encoded 32 bytes) ----------------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_MASTER_KEY=

# --- Vault storage --------------------------------------------------------
# "local" for dev (writes to ./.vault), "s3" for production
VAULT_DRIVER=local
# S3 (only if VAULT_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_KMS_KEY_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Rate limiting (Upstash Redis, optional in dev) --------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- WhatsApp Cloud API (Meta) -----------------------------------------------
# Required for production. Beta can run without it using the in-app invite flow.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- KYC / Screening providers (mocked unless set) ---------------------------
# Beta uses deterministic mocks. Production swaps in real keys.
TRULIOO_API_KEY=
COMPLY_ADVANTAGE_API_KEY=

# --- Operational --------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
