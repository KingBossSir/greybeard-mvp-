# Staging environment — copy to .env.staging (gitignored)
#
# Provision separately from prod:
#   - Neon: create a branch off main (`staging`)
#   - Resend: same domain works; use a different "from" address so QA mail is filterable
#   - Upstash: a separate Redis DB so staging rate-limits don't poison prod analytics
#   - WhatsApp: use Meta's test phone number, not the prod WABA
#
# Every secret below MUST be different from prod.

NODE_ENV=production
GREYBEARD_ENV=staging
NEXTAUTH_URL=https://staging.greybeard.app

# Different from prod
DATABASE_URL=postgresql://user:pass@ep-staging-XYZ.neon.tech/greybeard?sslmode=require

AUTH_SECRET=                # different from prod — generate fresh
LEDGER_SIGNING_KEY=         # different from prod — staging chain MUST NOT verify against prod pubkey
VAULT_MASTER_KEY=           # different from prod — staging vault MUST NOT decrypt prod blobs

RESEND_API_KEY=
EMAIL_FROM=staging@greybeard.app

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vault: local in containers, s3 in cloud staging
VAULT_DRIVER=local

# Providers: keep mocks on in staging so QA doesn't burn KYC quota
TRULIOO_API_KEY=mock
COMPLY_ADVANTAGE_API_KEY=mock

# WhatsApp: optional in staging — webhook GET handshake still works without it
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Staging-only: enables /api/staging/reset and /api/staging/seed
STAGING_OPS_TOKEN=          # generate: openssl rand -hex 32

LOG_LEVEL=debug
